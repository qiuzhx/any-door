{
  "name": "@any-door/mini-program",
  "version": "1.0.0",
  "private": true,
  "description": "any-door 微信小程序（Taro + Vite + TailwindCSS）",
  "scripts": {
    "build": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "lint": "echo \"@any-door/mini-program: linter todo\""
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@any-door/shared": "workspace:^",
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "marked": "^18.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-generator": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@types/node": "^22.19.3",
    "@types/react": "^18.3.18",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "babel-preset-taro": "4.2.0",
    "postcss": "^8.5.6",
    "react-refresh": "^0.14.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.39.0",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "weapp-tailwindcss": "^4.12.0"
  }
}
