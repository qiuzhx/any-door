# Copy to apps/api/.env（勿提交）
#
# ---- 选用哪一个后端 ----
# LLM_PROVIDER=cursor   # 强制 Cursor Agent SDK（需 CURSOR_API_KEY）
# LLM_PROVIDER=openai   # 强制 Vercel AI SDK / OpenAI 兼容（需 OPENAI_API_KEY）
# 不设则：有 CURSOR_API_KEY 时优先 Cursor，否则用 OPENAI_API_KEY

# ---- Cursor（本地 Agent，需要本机工作区目录）----
CURSOR_API_KEY=
# 可选：默认指向 monorepo 根目录；在 serverless 无仓库目录时需改成可写路径或改用云端 Agent（当前代码仅接入 local）
CURSOR_AGENT_CWD=
# 可选模型 id，默认 composer-2
CURSOR_MODEL=composer-2

# ---- OpenAI 兼容（Vercel AI SDK）----
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 可选：未传 system 消息时的默认系统提示
# CHAT_SYSTEM_PROMPT=
